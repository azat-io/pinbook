    <Folder>
      <name>Entertainment</name>
      <description>Evening plans and activity-focused stops.</description>
      <Placemark>
        <name>TeamLab Planets</name>
        <description><![CDATA[<img src="https://images.unsplash.com/photo-1556173251-cab2c1e8abe2" height="200" width="auto" /><br><br>Indoor slot for a rainy day. Reserve in advance to avoid sold-out times.]]></description>
        <ExtendedData>
          <Data name="gx_media_links">
            <value><![CDATA[https://images.unsplash.com/photo-1556173251-cab2c1e8abe2]]></value>
          </Data>
        </ExtendedData>
        <styleUrl>#icon-1636-303F9F</styleUrl>
        <Point>
          <coordinates>139.7897739,35.6491207,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Dotonbori</name>
        <description><![CDATA[<img src="https://images.unsplash.com/photo-1542210940661-5f91cb7afe02" height="200" width="auto" /><br><br>Dense evening area with food, crowds, and bright signage.]]></description>
        <ExtendedData>
          <Data name="gx_media_links">
            <value><![CDATA[https://images.unsplash.com/photo-1542210940661-5f91cb7afe02]]></value>
          </Data>
        </ExtendedData>
        <styleUrl>#icon-1577-5E35B1</styleUrl>
        <Point>
          <coordinates>135.5019145,34.6687142,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>Food</name>
      <description>Restaurants, cafes, and snack stops.</description>
      <Placemark>
        <name>Onibus Coffee Nakameguro</name>
        <description>Good morning coffee stop before exploring Nakameguro and Daikanyama.</description>
        <styleUrl>#icon-1534-00897B</styleUrl>
        <Point>
          <coordinates>139.6980318,35.6431767,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Gyukatsu Motomura Shibuya</name>
        <description>Popular beef cutlet spot near Shibuya. Queue risk is high at peak lunch hours.</description>
        <styleUrl>#icon-1577-E64A19</styleUrl>
        <Point>
          <coordinates>139.703795,35.6619707,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>Sights</name>
      <description>Major landmarks, temples, and viewpoints.</description>
      <Placemark>
        <name>Senso-ji</name>
        <description><![CDATA[<img src="https://images.unsplash.com/photo-1706813253696-10ee6332edd3" height="200" width="auto" /><br><br><img src="https://images.unsplash.com/photo-1702777326906-9c480b4b316c" height="200" width="auto" /><br><br>Good early-morning stop before the street gets crowded. Combine with a short walk around Asakusa.]]></description>
        <ExtendedData>
          <Data name="gx_media_links">
            <value><![CDATA[https://images.unsplash.com/photo-1706813253696-10ee6332edd3]]></value>
          </Data>
          <Data name="gx_media_links">
            <value><![CDATA[https://images.unsplash.com/photo-1702777326906-9c480b4b316c]]></value>
          </Data>
        </ExtendedData>
        <styleUrl>#icon-1523-F44336</styleUrl>
        <Point>
          <coordinates>139.7966553,35.7147651,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Shibuya Sky</name>
        <description><![CDATA[<img src="https://images.unsplash.com/photo-1697441222725-d9d2e403475c" height="200" width="auto" /><br><br>Best booked around sunset. Strong first-night option if the weather is clear.]]></description>
        <ExtendedData>
          <Data name="gx_media_links">
            <value><![CDATA[https://images.unsplash.com/photo-1697441222725-d9d2e403475c]]></value>
          </Data>
        </ExtendedData>
        <styleUrl>#icon-1523-4527A0</styleUrl>
        <Point>
          <coordinates>139.7019848,35.6586719,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Kiyomizu-dera</name>
        <description><![CDATA[<img src="https://images.unsplash.com/photo-1593297305192-ed4e59dd5777" height="200" width="auto" /><br><br>Best paired with an early walk through Higashiyama before the streets fill up.]]></description>
        <ExtendedData>
          <Data name="gx_media_links">
            <value><![CDATA[https://images.unsplash.com/photo-1593297305192-ed4e59dd5777]]></value>
          </Data>
        </ExtendedData>
        <styleUrl>#icon-1523-FB8C00</styleUrl>
        <Point>
          <coordinates>135.7850463,34.9948561,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>Stay</name>
      <description>Hotel and logistics-related pins.</description>
      <Placemark>
        <name>Hotel Groove Shinjuku</name>
        <description>Central base for evening plans in Shinjuku. Useful anchor point for daily route planning.</description>
        <styleUrl>#icon-1602-FFA000</styleUrl>
        <Point>
          <coordinates>139.7004066,35.6958759,0</coordinates>
        </Point>
      </Placemark>
    </Folder>
